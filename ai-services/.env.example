# Groq API
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192
GROQ_EMBEDDING_MODEL=llama3-8b-8192

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=admission_docs

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/admission-chat

# JWT (must match backend-node)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Whisper
WHISPER_MODEL=base

# RAG settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
